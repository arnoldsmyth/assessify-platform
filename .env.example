# Assessify environment (03 — Env/secrets: Zod-validated at boot, missing
# config fails fast). Copy to .env for local dev; in production these are
# DO App Platform encrypted env vars. Never commit real values.

# Neon Postgres connection string. Used by packages/db migrations, the
# repositories layer, and Better Auth (apps/web).
DATABASE_URL=postgres://user:password@host.neon.tech/assessify?sslmode=require

# Better Auth signing secret (apps/web). Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Canonical base URL of the web app (admin surface host).
BETTER_AUTH_URL=http://localhost:3000

# Respondent session cookie HMAC key (C1 token+PIN access flow; min 32 chars).
# Generate: openssl rand -base64 32
RESPONDENT_SESSION_SECRET=

# DigitalOcean Spaces (A4 object storage: branding assets, legacy PDFs).
# DO_SPACES_ENDPOINT is optional (defaults to the region's standard endpoint).
DO_SPACES_REGION=
DO_SPACES_BUCKET=
DO_SPACES_KEY=
DO_SPACES_SECRET=
# DO_SPACES_ENDPOINT=

# SendGrid (D4 mailer adapter). When SENDGRID_API_KEY is unset the worker
# falls back to the console mailer (local dev). The webhook public key is
# issued in the SendGrid console (Ed25519 or ECDSA, PEM or base64 DER).
SENDGRID_API_KEY=
SENDGRID_WEBHOOK_PUBLIC_KEY=

# Platform sender identity for non-product mail (e.g. admin auth emails).
# Product mail sender identities come from product branding config.
MAIL_FROM_NAME=Assessify
MAIL_FROM_ADDRESS=no-reply@assessify.ie

# Stripe (D3 payment adapter). Both optional in dev: without them card
# payments report provider_unavailable and the webhook answers 503.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Tenant resolution (F1, spec 11). Comma-separated hostname lists; the
# defaults shown cover local dev (localhost = admin surface,
# {slug}.localhost:3000 = white-label product surface). Production overrides
# these with the real assessify.ie hostnames via DO App Platform env vars.
ADMIN_HOSTNAMES=app.assessify.ie,localhost,127.0.0.1
PLATFORM_HOSTNAMES=assessify.ie,www.assessify.ie
PRODUCT_SLUG_BASE_DOMAINS=assessify.ie,localhost

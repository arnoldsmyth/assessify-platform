{
  "name": "assessify",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "eslint .",
    "lint:boundaries": "depcruise apps packages",
    "qdef": "pnpm --filter @assessify/questionnaire-schema exec tsx src/cli.ts",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp"]
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "dependency-cruiser": "^16.10.0",
    "eslint": "^9.20.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.30.0"
  }
}
